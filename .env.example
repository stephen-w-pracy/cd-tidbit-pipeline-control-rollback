# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real tokens.

# ---- Harness ----
# Your Harness account ID (find it in any Harness URL: .../account/<THIS>/...,
# or in Account Settings → Account Details).
HARNESS_ACCOUNT_ID=

# A Harness API key (Personal Access Token or Service Account Token).
# Used as the x-api-key header for all API calls. Needs permissions to create
# the resources below (and the project, if CREATE_PROJECT=true).
# Create one in: Account Settings → Access Control → (your user) → API Keys.
HARNESS_API_KEY=

# The org where the project lives. If CREATE_PROJECT=true, the project is
# created in this org (the org itself must already exist). Most accounts have
# a "default" org.
HARNESS_ORG=default

# The project identifier to use. If CREATE_PROJECT=true it will be created;
# otherwise it must already exist and you must have write access.
HARNESS_PROJECT=pipeline_controls

# true  → the script creates the project under HARNESS_ORG (needs project-create
#         permission on your API key).
# false → the script uses the existing HARNESS_ORG/HARNESS_PROJECT as-is.
CREATE_PROJECT=true

# ---- GitHub ----
# Your GitHub username (used in the GHCR image path and connector URLs).
GITHUB_USERNAME=

# The forked repo name (the script builds the GitHub URL from username + repo).
GITHUB_REPO=cd-tidbit-pipeline-control-rollback

# A GitHub Personal Access Token (classic) with `write:packages` and `repo`
# scopes. Stored as a Harness secret AND used for the cluster imagePullSecret.
GITHUB_PAT=

# ---- Delegate ----
# The delegate selector the K8s connector targets. Must match a tag on your
# installed delegate. The script tags the delegate it installs with this value.
DELEGATE_SELECTOR=helm-delegate

# Display name for the delegate the script installs via Helm.
DELEGATE_NAME=pipeline-controls-delegate
